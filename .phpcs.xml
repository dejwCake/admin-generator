<?xml version="1.0"?>
<ruleset name="Application">
    <description>Package coding standard.</description>

    <arg value="nsp" />
    <arg name="cache" value=".phpcs.cache" />

    <config name="php_version" value="80500" />

    <file>resources/</file>
    <file>src/</file>
    <file>tests/</file>
    <exclude-pattern>tests/**/__snapshots__/*</exclude-pattern>

    <!--not exactly nice, but working solution-->
    <rule ref="/root/.composer/vendor/dejwcake/php-code-style/base.phpcs.xml" />

    <rule ref="SlevomatCodingStandard.Files.TypeNameMatchesFileName">
        <properties>
            <property name="rootNamespaces" type="array">
                <element key="src" value="Brackets\AdminGenerator"/>
                <element key="tests" value="Brackets\AdminGenerator\Tests"/>
            </property>
        </properties>
    </rule>

    <rule ref="SlevomatCodingStandard.Complexity.Cognitive">
        <properties>
            <property name="maxComplexity" value="10"/>
        </properties>
        <exclude-pattern>src/Generators/FileAppenders/FileAppender.php</exclude-pattern>
        <exclude-pattern>src/Generators/GenerateUser.php</exclude-pattern>
        <exclude-pattern>tests/Feature/Generators/GenerateAdminUser/DefaultTest.php</exclude-pattern>
    </rule>

    <rule ref="SlevomatCodingStandard.Files.LineLength.LineTooLong">
        <exclude-pattern>src/Generators/Classes/Controller.php</exclude-pattern>
        <exclude-pattern>src/Generators/GenerateAdminUser.php</exclude-pattern>
        <exclude-pattern>src/Generators/GenerateAdminUserProfile.php</exclude-pattern>
        <exclude-pattern>src/Generators/GenerateUser.php</exclude-pattern>
        <exclude-pattern>tests/Feature/Builders/ColumnCollectionBuilderTest.php</exclude-pattern>
    </rule>
</ruleset>
