            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/console": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.1",
        "spatie/phpunit-snapshot-assertions": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "Brackets\\AdminGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brackets\\AdminGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev",
            "dev-v2-dev": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Brackets\\AdminGenerator\\AdminGeneratorServiceProvider"
            ]
        }
    }
