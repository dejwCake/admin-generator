    "description": "Laravel CRUD generator for dejwcake/craftable",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "generator",
        "make",
        "crud",
        "admin",
        "cms",
        "laravel",
        "craftable"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
